{
  "manifest_version": 3,
  "name": "SnipSearch",
  "version": "1.0.0",
  "description": "Store and semantically search code snippets with AI-powered hybrid search.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}